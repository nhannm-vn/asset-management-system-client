# === Cấu hình cho DEV PROXY (khuyến nghị, xem vite.config.ts) ===
# Địa chỉ backend .NET thật — Vite sẽ proxy /api và /hubs tới đây.
# Không cần sửa CORS ở backend khi dùng cách này.
VITE_BACKEND_TARGET=https://localhost:7146

# === Chỉ set 2 biến dưới nếu KHÔNG dùng proxy (vd: build production, ===
# === deploy FE/BE khác domain hẳn). Khi đó backend BẮT BUỘC phải cấu ===
# === hình CORS + AllowCredentials, và cookie Strict/Secure có thể cần ===
# === nới lỏng (xem README.md mục "Triển khai production"). ===
# VITE_API_BASE_URL=https://api.your-domain.com
# VITE_HUB_URL=https://api.your-domain.com/hubs/notifications
